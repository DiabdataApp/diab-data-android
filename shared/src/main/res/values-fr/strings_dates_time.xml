    <!-- Single strings for special cases -->
    <!-- Abbreviations -->
    <string name="date_abbr_today">auj</string>
    <string name="date_abbr_tomorrow">dem</string>
    <plurals name="date_abbr_days">
        <item quantity="one" tools:ignore="ImpliedQuantity">dem</item>
        <item quantity="other">%dj</item>
    </plurals>

    <!-- For current date -->
    <string name="date_today">Aujourd\'hui</string>
